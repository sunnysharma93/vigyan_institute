{
  "version": 2,
  "name": "vigyan-institute",
  "framework": "create-react-app",
  "regions": ["hkg1"],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "cache-control", "value": "s-maxage=31536000,immutable" },
        { "key": "x-robots-tag", "value": "noindex" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "cache-control", "value": "s-maxage=0,no-cache" },
        { "key": "service-worker-allowed", "value": "/" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}