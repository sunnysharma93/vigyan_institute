# Environment Configuration Template
# Copy this file to .env.local and update with your actual values

# Application Configuration
REACT_APP_NAME=Vigyan Institute
REACT_APP_TAGLINE=Shaping Future with Quality Education
REACT_APP_DESCRIPTION=Premier coaching institute providing quality education for JEE, NEET, and board exams

# Contact Information
REACT_APP_PHONE_MAIN=+91 12345 67890
REACT_APP_PHONE_BRANCH=+91 09876 54321
REACT_APP_PHONE_ADMISSIONS=+91 11223 44556

# Email Addresses
REACT_APP_EMAIL_INFO=info@vigyaninstitute.edu
REACT_APP_EMAIL_ADMISSIONS=admissions@vigyaninstitute.edu
REACT_APP_EMAIL_SUPPORT=support@vigyaninstitute.edu

# Address Information
REACT_APP_ADDRESS_STREET=Near Palla Chowk
REACT_APP_ADDRESS_AREA=Palla
REACT_APP_ADDRESS_CITY=Faridabad
REACT_APP_ADDRESS_STATE=Haryana
REACT_APP_ADDRESS_PINCODE=121004
REACT_APP_ADDRESS_LANDMARK=Opposite Palla Government School

# Branch Office Address
REACT_APP_BRANCH_STREET=Sector 15
REACT_APP_BRANCH_AREA=Faridabad
REACT_APP_BRANCH_CITY=Faridabad
REACT_APP_BRANCH_STATE=Haryana
REACT_APP_BRANCH_PINCODE=121007
REACT_APP_BRANCH_LANDMARK=Near Delhi-Mathura Road

# URLs
REACT_APP_SITE_URL=https://vigyan-institute.vercel.app
REACT_APP_API_URL=http://localhost:8080/api

# Social Media Links
REACT_APP_FACEBOOK=https://facebook.com/vigyaninstitute
REACT_APP_INSTAGRAM=https://instagram.com/vigyaninstitute
REACT_APP_TWITTER=https://twitter.com/vigyaninstitute
REACT_APP_LINKEDIN=https://linkedin.com/company/vigyaninstitute
REACT_APP_YOUTUBE=https://youtube.com/@vigyaninstitute

# Analytics (Optional)
REACT_APP_GA_TRACKING_ID=
REACT_APP_GTM_ID=

# EmailJS Configuration (for contact forms)
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_EMAILJS_PUBLIC_KEY=

# Office Hours
REACT_APP_OFFICE_HOURS_WEEKDAYS=Monday - Friday: 9:00 AM - 6:00 PM
REACT_APP_OFFICE_HOURS_SATURDAY=Saturday: 9:00 AM - 2:00 PM
REACT_APP_OFFICE_HOURS_SUNDAY=Sunday: Closed

# Statistics
REACT_APP_STUDENTS_TAUGHT=5000+
REACT_APP_SUCCESS_RATE=95%
REACT_APP_PROGRAMS=25+
REACT_APP_FACULTY_MEMBERS=50+

# Google Reviews
REACT_APP_GOOGLE_RATING=5.0
REACT_APP_TOTAL_REVIEWS=5
REACT_APP_GOOGLE_REVIEWS_URL=https://www.google.com/search?q=vigyan+institute+faridabad

# Feature Flags
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_PWA=true
